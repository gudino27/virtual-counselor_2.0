# Backend API Dockerfile
FROM node:22-slim

# Install build dependencies for better-sqlite3 and Python pipeline
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv \
    make g++ sqlite3 \
    wget \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install Node dependencies
RUN npm ci --only=production

# Set up Python venv and install prompt-search production dependencies
COPY prompt-search/requirements.txt ./prompt-search/requirements.txt
RUN python3 -m venv prompt-search/venv && \
    prompt-search/venv/bin/pip install --no-cache-dir --upgrade pip && \
    prompt-search/venv/bin/pip install --no-cache-dir \
        "numpy>=1.24,<2.0" && \
    prompt-search/venv/bin/pip install --no-cache-dir \
        --extra-index-url https://download.pytorch.org/whl/cpu \
        torch && \
    prompt-search/venv/bin/pip install --no-cache-dir \
        pyyaml \
        pydantic \
        python-dotenv \
        "anthropic>=0.40.0" \
        requests \
        "sentence-transformers>=2.7,<3.0" \
        "faiss-cpu>=1.11" \
        rank_bm25

# Copy application files
COPY server-sqlite.js ./
COPY logger.js ./
COPY pdf-archieved-catalog ./pdf-archieved-catalog
COPY prompt-search ./prompt-search

# Create data directory
RUN mkdir -p /app/data

# Expose API port
EXPOSE 3008

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
  CMD wget --quiet --tries=1 --spider http://localhost:3008/health || exit 1

# Start server
CMD ["node", "server-sqlite.js"]
